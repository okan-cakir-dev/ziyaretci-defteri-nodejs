<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modern Ziyaretçi Defteri</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/style.css">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body { font-family: 'Poppins' sans-serif; }
        .mesaj-karti { transition: transform 0.2s; }
        .mesaj-karti:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
    </style>
</head>
<body>

    <div class="container mt-5">

        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold text-primary">📒 Ziyaretçi Defteri</h1>
            <p class="lead text-secondary">Mesajınızı bırakın, tarihe not düşün.</p>
        </div>

        <div class="row">

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">✍️ Yeni Mesaj Yaz</h5>   
                    </div>
                    <div class="card-body">
                        <form action="/ekle" method="POST">
                            <div class="mb-3">
                                <label class="form-label">İsim</label>
                                <input type="text" name="isim" class="form-control" placeholder="Adınız..." required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Mesaj</label>
                                <textarea name="not" class="form-control" rows="4" placeholder="Buraya yazın..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary w-1oo">Gönder 🚀</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <h4 class="mb-3">Son Mesajlar</h4>

                <% if (gelenMesajlar.length === 0) { %>
                    <div class="alert alert-warning">Henüz hiç mesaj yok. İlk yazan sen ol!</div>
                <% } %>

                <div class="vstack gap-3">
                    <% gelenMesajlar.forEach(function(veri, sira) { %>
                        <div class="card mesaj-karti border-start border-4 border-primary shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title fw-bold text-dark">
                                    <%= veri.isim %>
                                </h5>
                                <p class="card-text text-muted">
                                    <%= veri.not %>
                                </p>

                                <div class="d-flex justify-content-end gap-2 mt-3">
                                    <a href="/duzenle/<%= sira %>" class="btn btn-sm btn-outline-warning">Düzenle ✏️</a>
                                    <a href="/sil/<%= sira %>" class="btn btn-sm btn-outline-danger">Sil 🗑️</a>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>
    
</body>
</html>