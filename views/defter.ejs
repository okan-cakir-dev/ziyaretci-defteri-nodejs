<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ziyaretçi Defteri</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="container mt-5">
        <h1 class="text-center mb-4">📖 Ziyaretçi Defteri</h1>

        <div class="card p-4 shadow-sm mb-5">
            <form action="/ekle" method="POST">
                <div class="mb-3">
                    <label>Adınız:</label>
                    <input type="text" name="isim" class="form-control" required placeholder="Adınızı yazın...">
                </div>
                <div class="mb-3">
                    <label>Mesajınız:</label>
                    <textarea name="not" class="form-control" rows="3" required placeholder="Mesajınızı yazın..."></textarea>
                </div>
                <button type="submit" class="btn btn-primary w-100">Kaydet</button>
            </form>
        </div>

        <h3 class="mb-3">Son Mesajlar</h3>
        
        <% if(mesajlar.length > 0) { %>
            <% mesajlar.forEach(function(mesaj) { %>
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title"><%= mesaj.isim %></h5>
                        <p class="card-text"><%= mesaj.not %></p>
                        <small class="text-muted"><%= mesaj.tarih.toLocaleDateString() %></small>
                        
                        <div class="float-end">
                            <a href="/duzenle/<%= mesaj._id %>" class="btn btn-warning btn-sm">Düzenle</a>
                            <a href="/sil/<%= mesaj._id %>" class="btn btn-danger btn-sm">Sil</a>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="alert alert-info">Henüz hiç mesaj yok. İlk yazan sen ol!</div>
        <% } %>

    </div>
</body>
</html>