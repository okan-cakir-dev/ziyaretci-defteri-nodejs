<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mesajı Düzenle</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; font-family: sans-serif; }
    </style>
</head>
<body>

    <div class="container d-flex justify-content-center aling-items-center" style="height: 100vh;">
        <div class="col-md-6">

            <div class="card-shadow-lg border-0">
                <div class="card-header bg-warning text-dark fw-bold">
                    ✏️ Mesajı Düzenle
                </div>
                <div class="card-body p-4">

                    <form action="/guncelle/<%= id %>" method="POST">

                        <div class="mb-3">
                            <label class="form-label text-muted">İsim</label>
                            <input type="text" name="isim" class="form-control form-control-lg" value="<%= veri.isim %>" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted">Mesaj</label>
                            <textarea name="not" class="form-control" rows="5" required><%= veri.not %></textarea>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning btn-lg text-white fw-bold">KAYDET VE GÜNCELLE</button>
                            <a href="/" class="btn btn-light text-muted">İptal Et</a>
                        </div>

                    </form>

                </div>
            </div>
            
        </div>
    </div>
    
</body>
</html>